@model IEnumerable<uploadphoto.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold text-primary mb-0">Quản lý sản phẩm</h1>
            <p class="text-muted mb-0">Danh sách các sản phẩm và hình ảnh minh họa</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center p-5 border-0 shadow-sm rounded-4 bg-light">
            <div class="card-body">
                <i class="bi bi-box-seam display-1 text-muted mb-3"></i>
                <h4 class="fw-semibold">Chưa có sản phẩm nào</h4>
                <p class="text-muted">Hãy thêm sản phẩm đầu tiên cùng các hình ảnh giới thiệu của nó.</p>
                <a asp-action="Create" class="btn btn-primary">Thêm ngay</a>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                var carouselId = "carouselProduct" + item.Id;
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card transition-all">
                        
                        <!-- Image Area -->
                        <div class="position-relative bg-light card-img-wrapper" style="height: 250px;">
                            @if (item.ImageUrls == null || item.ImageUrls.Count == 0)
                            {
                                <div class="w-100 h-100 d-flex flex-column justify-content-center align-items-center text-muted border-bottom">
                                    <i class="bi bi-image display-4 mb-2"></i>
                                    <span class="small fw-semibold">Không có hình ảnh</span>
                                </div>
                            }
                            else if (item.ImageUrls.Count == 1)
                            {
                                <img src="@item.ImageUrls[0]" class="w-100 h-100 object-fit-cover border-bottom" alt="@item.Name" />
                            }
                            else
                            {
                                <!-- Carousel for multiple images -->
                                <div id="@carouselId" class="carousel slide w-100 h-100 border-bottom" data-bs-ride="carousel">
                                    <div class="carousel-indicators">
                                        @for (int i = 0; i < item.ImageUrls.Count; i++)
                                        {
                                            <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i+1)"></button>
                                        }
                                    </div>
                                    <div class="carousel-inner h-100">
                                        @for (int i = 0; i < item.ImageUrls.Count; i++)
                                        {
                                            <div class="carousel-item h-100 @(i == 0 ? "active" : "")">
                                                <img src="@item.ImageUrls[i]" class="d-block w-100 h-100 object-fit-cover" alt="@item.Name (@(i+1))" />
                                            </div>
                                        }
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                        <span class="visually-hidden">Previous</span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                        <span class="visually-hidden">Next</span>
                                    </button>
                                </div>
                            }
                            
                            @if (item.ImageUrls != null && item.ImageUrls.Count > 1)
                            {
                                <span class="position-absolute top-0 end-0 bg-dark bg-opacity-75 text-white fs-xs px-2.5 py-1 m-3 rounded-pill fw-semibold small z-3">
                                    <i class="bi bi-images"></i> @item.ImageUrls.Count ảnh
                                </span>
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark mb-1 text-truncate">@item.Name</h5>
                            <p class="card-text text-danger fw-bold fs-5 mb-3">
                                @item.Price.ToString("#,##0") <span class="fs-6 fw-normal text-muted">VND</span>
                            </p>
                            
                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary flex-grow-1 rounded-pill">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">
                                        <i class="bi bi-trash"></i> Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .product-card {
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }
        .object-fit-cover {
            object-fit: cover;
        }
        .fs-xs {
            font-size: 0.75rem;
        }
        .px-2\.5 {
            padding-left: 0.6rem;
            padding-right: 0.6rem;
        }
        .py-1 {
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
        }
        .z-3 {
            z-index: 3;
        }
    </style>
}
